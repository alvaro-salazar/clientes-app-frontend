# Copia este archivo como .env y ajusta los valores
# NUNCA subas .env a un repositorio — está en .gitignore

# Imagen de usuario-service
# Cambia por tu propia imagen publicada en el Paso 9 del codelab
USUARIO_SERVICE_IMAGE=alvarosalazar/usuario-service:codelab-05

# Credenciales de MinIO (cambia en producción)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Secret del service account de Keycloak
KEYCLOAK_ADMIN_CLIENT_SECRET=usuario-service-secret
